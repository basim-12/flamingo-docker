{
  "services": {
    "app": {
      "build": { "context": "." },
      "volumes": [
        "${FLAMINGO_PATH}/data:/data",
        "${FLAMINGO_PATH}:/app",
        "/app/node_modules",
        "./env.docker.json:/config/env.docker.json"
      ],
      "ports": [
        "8080:8080"
      ],
      "environment": {
        "ENV_FILE": "/config/env.docker.json"
      },
      "command": [
        "bash",
        "-c",
        "cd /app && npm install && npm run cli start"
      ]
    }
  }
}
