{
  "services": {
    "app": {
      "build": { "context": "." },
      "volumes": [
        {
          "source": "../flamingo-node/data",
          "target": "/data"
        },
        {
          "source": "../flamingo-node",
          "target": "/app"
        },
        {
          "target": "/app/node_modules"
        },
        {
          "source": "./env.docker.json",
          "target": "/config/env.docker.json"
        }
      ],
      "ports": [
        {
          "published": 8080,
          "target": 8080
        }
      ],
      "environment": {
        "ENV_FILE": "/config/env.docker.json"
      },
      "command": [
        "bash",
        "-c",
        "cd /app && npm install && npm run cli start"
      ]
    }
  }
}
